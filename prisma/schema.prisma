generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id         String   @id @db.Uuid
  name       String
  bio        String
  avatar_url String?
  location   String
  interests  String[]
  created_at DateTime @db.Timestamptz(6)

  user_events    UserEvent[]
  room_members   RoomMember[]
  chat_messages  ChatMessage[]

  @@map("profiles")
}

model UserEvent {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String   @db.Uuid
  event_id        String
  event_title     String?
  event_image_url String?
  event_address   String?
  action          String
  created_at      DateTime @db.Timestamptz(6)

  profile Profile @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, event_id, action])
  @@index([user_id, action, created_at(sort: Desc)])
  @@index([event_id])
  @@map("user_events")
}

model ChatRoom {
  id              String   @id
  event_title     String
  event_image_url String?
  event_address   String?
  created_at      DateTime @db.Timestamptz(6)

  room_members  RoomMember[]
  chat_messages ChatMessage[]

  @@map("chat_rooms")
}

model RoomMember {
  room_id      String
  user_id      String   @db.Uuid
  joined_at    DateTime @db.Timestamptz(6)
  last_read_at DateTime @db.Timestamptz(6)

  room    ChatRoom @relation(fields: [room_id], references: [id], onDelete: Cascade)
  profile Profile  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([room_id, user_id])
  @@index([user_id])
  @@index([room_id])
  @@map("room_members")
}

model ChatMessage {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  room_id    String
  user_id    String   @db.Uuid
  text       String
  created_at DateTime @db.Timestamptz(6)

  room    ChatRoom @relation(fields: [room_id], references: [id], onDelete: Cascade)
  profile Profile  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([room_id, created_at(sort: Desc)])
  @@index([user_id])
  @@map("chat_messages")
}
