# Auth Microservice
PORT=3001

# Supabase
SUPABASE_URL=tu_url_supabase
SUPABASE_ANON_KEY=tu_anon_key
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# Frontend (para redirigir después de OAuth)
FRONTEND_ORIGIN=http://localhost:3000

# IMPORTANTE: En Supabase, configura el Redirect URL (OAuth) en:
# https://app.supabase.com → Authentication → URL Configuration
# Redirect URLs: http://localhost:3001/auth/callback
# El endpoint /auth/callback se movió desde app-web a este microservicio
