# Admin Microservice
PORT=3007

# Supabase
SUPABASE_URL=tu_url_supabase
SUPABASE_ANON_KEY=tu_anon_key
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# Frontend
FRONTEND_ORIGIN=http://localhost:3000

# Nota: El callback de autenticación (OAuth) se encuentra en app-auth (puerto 3001)
# En Supabase, configura el Redirect URL en:
# https://app.supabase.com → Authentication → URL Configuration
# Redirect URLs: http://localhost:3001/auth/callback

