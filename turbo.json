{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "start": {
      "dependsOn": ["build"],
      "persistent": true,
      "cache": false
    },
    "test": {
      "outputs": []
      },
      "db:generate": {
        "cache": false
      },
      "db:push": {
        "cache": false
      },
      "db:migrate:deploy": {
        "cache": false
      }
  }
}
