# eMeet Frontend — Variables de entorno
# Copia este archivo como .env.local y completa con tus valores reales.
# NUNCA subas .env.local ni .env.production a git.

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_publica

# ⚠️  SERVICE ROLE KEY: SOLO debe existir en el backend (Express/Node), NUNCA en el frontend.
#     Esta key bypasea Row Level Security — si está en el frontend es un riesgo crítico.
# SUPABASE_SERVICE_ROLE_KEY=

# ─── Backend API ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# ─── Base de datos (solo si usas Prisma directo desde Next.js) ────────────────
# DATABASE_URL=postgresql://postgres:password@db.tu-proyecto.supabase.co:5432/postgres

# ─── Google Maps ──────────────────────────────────────────────────────────────
# Obtén tu API key en: https://console.cloud.google.com/apis/credentials
# Activa: Maps JavaScript API, Places API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=tu_google_maps_api_key
