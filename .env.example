# Variables de entorno para eMeet Frontend
# Copia este archivo como .env.local y completa los valores reales.
# NUNCA subas .env.local a git.

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── Prisma / PostgreSQL ─────────────────────────────────────────────────────
DATABASE_URL=your_supabase_postgres_connection_string

# ─── Google Maps ─────────────────────────────────────────────────────────────
# Obtén tu API key en: https://console.cloud.google.com/apis/credentials
# Activa el API: Maps JavaScript API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
